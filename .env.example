# Datos upstream (dumps / v1)
NUXT_PUBLIC_API_BASE_URL=https://api.argentinadatos.com

# Sitio del build hybrid SSG: diputados | senadores | congreso
NUXT_PUBLIC_DEFAULT_CHAMBER=senadores

# Mini-API (`/api/*`). Vacío = same-origin.
# NUXT_PUBLIC_APP_API_BASE_URL=

# CORS para `/api/*` (comma-separated: exacto, sufijo o *)
# NUXT_CORS_ORIGINS=

# Secreto para POST /api/revalidate (limpia caches en memoria del proceso)
NUXT_REVALIDATE_SECRET=changeme

# Runtime (Coolify suele inyectar PORT)
# HOST=0.0.0.0
# PORT=3000
